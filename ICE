local InfoTab = Window:CreateTab("Player Info", 4483362458)
local UserLabel = InfoTab:CreateLabel("User: " .. LocalPlayer.Name)
local ServerLabel = InfoTab:CreateLabel("Players: " .. #Players:GetPlayers())
local UptimeLabel = InfoTab:CreateLabel("Uptime: 0s")

task.spawn(function()
    while task.wait(1) do
        ServerLabel:Set("Players: " .. #Players:GetPlayers())
        UptimeLabel:Set("Uptime: " .. math.floor(os.time() - startTime) .. "s")
    end
end)

