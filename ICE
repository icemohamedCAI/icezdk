})

MainTab:CreateToggle({
   Name = "choufo",
   CurrentValue = false,
   Callback = function(Value)
      viewingPlayer = Value
      local cam = Workspace.CurrentCamera
      if viewingPlayer then
          local target = getTargetPlayer()
          if target and target.Character and target.Character:FindFirstChild("Humanoid") then
              cam.CameraSubject = target.Character.Humanoid
          end
      else
          if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
              cam.CameraSubject = LocalPlayer.Character.Humanoid
          end
      end
   end,
})

MainTab:CreateToggle({
   Name = "fa3l 3lih",
   CurrentValue = false,
   Callback = function(Value)
      isTrolling = Value
      local char = LocalPlayer.Character
      local root = char and char:FindFirstChild("HumanoidRootPart")
      local hum = char and char:FindFirstChild("Humanoid")
      local target = getTargetPlayer()

      if isTrolling then
          -- Start Notification
          Rayfield:Notify({Title = "ICE V1", Content = "NIKLO OMO", Duration = 3})
          
          if root then lastCheckpoint = root.CFrame end
          if hum then hum.Sit = true end
          
          -- Mid-Bang Notification Timer (between 1 and 3 minutes)
          midBangThread = task.delay(math.random(60, 180), function()
              if isTrolling then
                  Rayfield:Notify({Title = "ICE V1", Content = "Mat5rjch Rak rajel", Duration = 4})
              end
          end)
          
          loopConnection = RunService.Heartbeat:Connect(function()
              if not isTrolling then return end
              local currentTarget = getTargetPlayer()
              
              -- Player Left logic
              if not currentTarget then
                  isTrolling = false
                  if loopConnection then loopConnection:Disconnect() end
                  if root and lastCheckpoint then root.CFrame = lastCheckpoint end
                  Rayfield:Notify({Title = "Target Left", Content = "Haw 5raj Mala 9ahba", Duration = 5})
                  return
              end

              if currentTarget.Character and currentTarget.Character:FindFirstChild("Head") and root then
                  local offset = currentTarget.Character.Head.CFrame * CFrame.new(0, 0, -1.2) 
                  local randomRotate = CFrame.Angles(math.rad(math.random(-glitchIntensity*10, glitchIntensity*10)), math.rad(math.random(-glitchIntensity*10, glitchIntensity*10)), 0)
                  root.CFrame = offset * randomRotate
                  if hum and not hum.Sit then hum.Sit = true end
              end
          end)
      else
          -- Toggled Off manually
          if loopConnection then loopConnection:Disconnect() end
          if midBangThread then task.cancel(midBangThread) end -- Cancel the timer if turned off early
          
          -- Check if player is still there
          if target then
              Rayfield:Notify({Title = "ICE V1", Content = "ya 5awaf 3leh 9asit 3lih?", Duration = 4})
          end
          
          if root and lastCheckpoint then root.CFrame = lastCheckpoint end
          if hum then hum.Sit = false end
      end
   end,
})

