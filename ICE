RunService.Heartbeat:Connect(function()
    local char = lp.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    
    if (isTrolling or mode1Enabled or mode2Enabled) and bangTarget and bangTarget.Character then
        local targetRoot = bangTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
            root.AssemblyLinearVelocity = Vector3.new(0,0,0)
            root.AssemblyAngularVelocity = Vector3.new(0,0,0)

            local shake = math.sin(tick() * 35) * 1.4

            if mode1Enabled then
                -- SEX 1: STANDING BEHIND
                hum.Sit = false
                root.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 1.1 + shake)
            elseif mode2Enabled then
                -- SEX 2: SITTING FACING (HEAD AIM)
                hum.Sit = true
                root.CFrame = targetRoot.CFrame * CFrame.new(0, 1.5, -1.1 - shake) * CFrame.Angles(0, math.rad(180), 0)
            elseif isTrolling then
                -- NIKOOOO (Random Spin)
                hum.Sit = true
                root.CFrame = targetRoot.CFrame * CFrame.new(0, 0, -1) * CFrame.Angles(math.rad(math.random(-180,180)), math.rad(math.random(-180,180)), 0)
                root.AssemblyAngularVelocity = Vector3.new(0, 800, 0)
            end
        end
    else
        if not antiBangActive then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
        end
    end

    -- Anti-Void Logic
    if antiVoidActive then
        if root.Position.Y < -80 then
            root.CFrame = CFrame.new(root.Position.X, -100, root.Position.Z)
            root.AssemblyLinearVelocity = Vector3.new(0,0,0)
        end
    else
        if root.Position.Y > 0 then lastCheckpoint = root.CFrame end
    end
end)

